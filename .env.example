# Runtime
NODE_ENV=production
PORT=3001

# Traefik / TLS
DOMAIN=api.yourdomain.com
ACME_EMAIL=your-email@yourdomain.com

# Database
# For local development, point to localhost. docker-compose overrides this with the service name.
DATABASE_URL=mysql://oliveto:change_me_db_password@localhost:3306/oliveto
# Required by docker-compose to create the MySQL container
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PASSWORD=change_me_db_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_min_32_chars_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_min_32_chars_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,https://your-frontend.hostingersite.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=contato@yourfirm.com.br
ADMIN_NOTIFICATION_EMAIL=admin@yourfirm.com.br

# Sentry
SENTRY_DSN=https://xxx@sentry.io/yyy

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
