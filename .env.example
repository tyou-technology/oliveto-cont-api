# Runtime
NODE_ENV=production
PORT=8080

# Traefik / TLS
DOMAIN=api.yourdomain.com
ACME_EMAIL=your-email@yourdomain.com

# Database — connection string provided by Hostinger managed PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis — connection string provided by Hostinger managed Redis
REDIS_URL=redis://host:6379

# JWT
JWT_SECRET=change_me_min_32_chars_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_min_32_chars_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,https://your-frontend.hostingersite.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=contato@yourfirm.com.br
ADMIN_NOTIFICATION_EMAIL=admin@yourfirm.com.br

# Sentry
SENTRY_DSN=https://xxx@sentry.io/yyy

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
