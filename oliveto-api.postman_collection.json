{
  "info": {
    "name": "Oliveto API",
    "description": "REST API for Oliveto accounting firm. Handles user management, authentication, blog articles, tags, and lead capture.\n\n## Setup\n1. Import this collection and the **Oliveto API** environment.\n2. Set `baseUrl` to `http://localhost:3001/api` (or your deployed URL).\n3. Run **POST /auth/login** — the `accessToken` and `refreshToken` variables will be set automatically via the test script.\n\n## Auth\n- Public endpoints require no token.\n- Protected endpoints read `{{accessToken}}` from the active environment.\n- Admin-only endpoints additionally require the `ADMIN` role on the authenticated user.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — register, login, token refresh, and logout.\n\nAll endpoints are public (no JWT required). Successful login/register/refresh responses return a token pair directly (no envelope wrapper).",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@example.com\",\n  \"password\": \"senha1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new user account. Returns an access + refresh token pair on success.\n\n**Rate limit:** 10 req / 60 s"
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@example.com\",\n  \"password\": \"senha1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Authenticate with email + password. Returns an access + refresh token pair.\n\n**Rate limit:** 10 req / 60 s"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": {\n    \"statusCode\": 401,\n    \"code\": \"UNAUTHORIZED\",\n    \"message\": \"Invalid credentials\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Exchange a valid refresh token for a new access + refresh token pair (rotation).\n\n**Rate limit:** 10 req / 60 s"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 204) {",
                  "  pm.collectionVariables.set('accessToken', '');",
                  "  pm.collectionVariables.set('refreshToken', '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Blacklist the provided refresh token, invalidating the session.\n\nReturns **204 No Content**. The test script clears the stored tokens.\n\n**Rate limit:** 10 req / 60 s"
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profile and management.\n\n- `/users/me` — authenticated user's own profile (any role).\n- `/users` and `/users/:id/role` — admin-only management.",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] },
            "description": "Returns the authenticated user's own profile. Requires a valid JWT."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": {\n    \"id\": \"clx7abc123\",\n    \"email\": \"joao@example.com\",\n    \"name\": \"João Silva\",\n    \"role\": \"ADMIN\",\n    \"avatarUrl\": null,\n    \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-01-01T00:00:00.000Z\"\n  },\n  \"_links\": {\n    \"self\": { \"href\": \"/users/me\", \"method\": \"GET\" },\n    \"update\": { \"href\": \"/users/me\", \"method\": \"PATCH\" }\n  }\n}"
            }
          ]
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João da Silva\",\n  \"password\": \"novaSenha1234\",\n  \"avatarUrl\": \"https://example.com/avatar.png\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Update the authenticated user's name, password, and/or avatar URL. All fields are optional."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": {\n    \"id\": \"clx7abc123\",\n    \"email\": \"joao@example.com\",\n    \"name\": \"João da Silva\",\n    \"role\": \"ADMIN\",\n    \"avatarUrl\": \"https://example.com/avatar.png\",\n    \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-03-08T12:00:00.000Z\"\n  },\n  \"_links\": {\n    \"self\": { \"href\": \"/users/me\", \"method\": \"GET\" },\n    \"update\": { \"href\": \"/users/me\", \"method\": \"PATCH\" }\n  }\n}"
            }
          ]
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (min: 1)" },
                { "key": "limit", "value": "10", "description": "Items per page (min: 1, max: 100)" },
                { "key": "sort", "value": "", "description": "Sort field", "disabled": true }
              ]
            },
            "description": "Paginated list of all users. **Requires ADMIN role.**"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": [\n    {\n      \"id\": \"clx7abc123\",\n      \"email\": \"joao@example.com\",\n      \"name\": \"João Silva\",\n      \"role\": \"ADMIN\",\n      \"avatarUrl\": null,\n      \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n      \"updatedAt\": \"2026-01-01T00:00:00.000Z\"\n    }\n  ],\n  \"meta\": {\n    \"page\": 1,\n    \"limit\": 10,\n    \"total\": 1,\n    \"totalPages\": 1\n  },\n  \"_links\": {\n    \"self\": { \"href\": \"/users\", \"method\": \"GET\" }\n  }\n}"
            }
          ]
        },
        {
          "name": "Change User Role (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/users/:id/role",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id", "role"],
              "variable": [{ "key": "id", "value": "clx7abc123", "description": "Target user ID" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"EDITOR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Change a user's role. **Requires ADMIN role.** An admin cannot change their own role.\n\n**Allowed roles:** `ADMIN`, `EDITOR`, `USER`"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": {\n    \"id\": \"clx7abc123\",\n    \"email\": \"joao@example.com\",\n    \"name\": \"João Silva\",\n    \"role\": \"EDITOR\",\n    \"avatarUrl\": null,\n    \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-03-08T12:00:00.000Z\"\n  },\n  \"_links\": {\n    \"self\": { \"href\": \"/users/clx7abc123\", \"method\": \"GET\" },\n    \"collection\": { \"href\": \"/users\", \"method\": \"GET\" }\n  }\n}"
            },
            {
              "name": "403 Forbidden (own role)",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": {\n    \"statusCode\": 403,\n    \"code\": \"FORBIDDEN\",\n    \"message\": \"Cannot change your own role\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Articles",
      "description": "Blog article management.\n\n- Public read endpoints: `GET /articles/published`, `GET /articles/slug/:slug`.\n- All other endpoints require ADMIN role.",
      "item": [
        {
          "name": "List Published Articles (Public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/articles/published?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["articles", "published"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (min: 1)" },
                { "key": "limit", "value": "10", "description": "Items per page (min: 1)" },
                { "key": "tagId", "value": "", "description": "Filter by tag ID", "disabled": true },
                { "key": "search", "value": "", "description": "Full-text search in title/content", "disabled": true }
              ]
            },
            "description": "Returns paginated PUBLISHED articles. No authentication required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": [\n    {\n      \"id\": \"clx8def456\",\n      \"title\": \"Como Declarar o Imposto de Renda 2026\",\n      \"slug\": \"como-declarar-imposto-renda-2026\",\n      \"content\": \"...\",\n      \"briefing\": \"Guia completo para declaração de IR.\",\n      \"readingTime\": 8,\n      \"status\": \"PUBLISHED\",\n      \"coverUrl\": \"https://cdn.example.com/cover.jpg\",\n      \"seoTitle\": null,\n      \"seoDescription\": null,\n      \"authorId\": \"clx7abc123\",\n      \"author\": { \"id\": \"clx7abc123\", \"name\": \"João Silva\", \"avatarUrl\": null },\n      \"tags\": [{ \"id\": \"clxtag001\", \"name\": \"Imposto de Renda\", \"color\": \"#2563EB\" }],\n      \"createdAt\": \"2026-02-01T00:00:00.000Z\",\n      \"updatedAt\": \"2026-02-10T00:00:00.000Z\",\n      \"publishedAt\": \"2026-02-10T00:00:00.000Z\"\n    }\n  ],\n  \"meta\": { \"page\": 1, \"limit\": 10, \"total\": 1, \"totalPages\": 1 },\n  \"_links\": { \"self\": { \"href\": \"/articles/published\", \"method\": \"GET\" } }\n}"
            }
          ]
        },
        {
          "name": "Get Article by Slug (Public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/articles/slug/:slug",
              "host": ["{{baseUrl}}"],
              "path": ["articles", "slug", ":slug"],
              "variable": [{ "key": "slug", "value": "como-declarar-imposto-renda-2026", "description": "Article slug" }]
            },
            "description": "Fetch a single article by its URL slug. No authentication required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": {\n    \"id\": \"clx8def456\",\n    \"title\": \"Como Declarar o Imposto de Renda 2026\",\n    \"slug\": \"como-declarar-imposto-renda-2026\",\n    \"content\": \"...\",\n    \"briefing\": \"Guia completo para declaração de IR.\",\n    \"readingTime\": 8,\n    \"status\": \"PUBLISHED\",\n    \"coverUrl\": \"https://cdn.example.com/cover.jpg\",\n    \"seoTitle\": null,\n    \"seoDescription\": null,\n    \"authorId\": \"clx7abc123\",\n    \"author\": { \"id\": \"clx7abc123\", \"name\": \"João Silva\", \"avatarUrl\": null },\n    \"tags\": [],\n    \"createdAt\": \"2026-02-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-02-10T00:00:00.000Z\",\n    \"publishedAt\": \"2026-02-10T00:00:00.000Z\"\n  },\n  \"_links\": {\n    \"self\": { \"href\": \"/articles/slug/como-declarar-imposto-renda-2026\", \"method\": \"GET\" },\n    \"collection\": { \"href\": \"/articles\", \"method\": \"GET\" }\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": {\n    \"statusCode\": 404,\n    \"code\": \"NOT_FOUND\",\n    \"message\": \"Article not found\"\n  }\n}"
            }
          ]
        },
        {
          "name": "List All Articles (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/articles?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["articles"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (min: 1)" },
                { "key": "limit", "value": "10", "description": "Items per page (min: 1)" },
                { "key": "status", "value": "", "description": "Filter: DRAFT | PUBLISHED | ARCHIVED", "disabled": true },
                { "key": "tagId", "value": "", "description": "Filter by tag ID", "disabled": true },
                { "key": "search", "value": "", "description": "Full-text search", "disabled": true }
              ]
            },
            "description": "Paginated list of all articles regardless of status. **Requires ADMIN role.**"
          },
          "response": []
        },
        {
          "name": "Get Article by ID (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/articles/:id",
              "host": ["{{baseUrl}}"],
              "path": ["articles", ":id"],
              "variable": [{ "key": "id", "value": "clx8def456", "description": "Article ID" }]
            },
            "description": "Fetch a single article by its ID. **Requires ADMIN role.**"
          },
          "response": []
        },
        {
          "name": "Create Article (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/articles", "host": ["{{baseUrl}}"], "path": ["articles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Como Declarar o Imposto de Renda 2026\",\n  \"content\": \"Neste artigo, vamos explicar o passo a passo para declarar o Imposto de Renda em 2026...\",\n  \"briefing\": \"Guia completo e atualizado para a declaração do IR 2026.\",\n  \"readingTime\": 8,\n  \"tagIds\": [\"clxtag001\"],\n  \"coverUrl\": \"https://cdn.example.com/cover.jpg\",\n  \"seoTitle\": \"IR 2026: Como Declarar o Imposto de Renda\",\n  \"seoDescription\": \"Aprenda a declarar o IR 2026 com nosso guia completo.\",\n  \"status\": \"DRAFT\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new article. The author is set automatically to the authenticated user.\n\n**Requires ADMIN role.**\n\n`status` defaults to `DRAFT` if omitted."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": {\n    \"id\": \"clx8def456\",\n    \"title\": \"Como Declarar o Imposto de Renda 2026\",\n    \"slug\": \"como-declarar-imposto-renda-2026\",\n    \"status\": \"DRAFT\",\n    \"readingTime\": 8,\n    \"publishedAt\": null,\n    \"createdAt\": \"2026-03-08T12:00:00.000Z\",\n    \"updatedAt\": \"2026-03-08T12:00:00.000Z\"\n  },\n  \"_links\": {\n    \"self\": { \"href\": \"/articles/slug/como-declarar-imposto-renda-2026\", \"method\": \"GET\" },\n    \"collection\": { \"href\": \"/articles\", \"method\": \"GET\" }\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Article (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/articles/:id",
              "host": ["{{baseUrl}}"],
              "path": ["articles", ":id"],
              "variable": [{ "key": "id", "value": "clx8def456", "description": "Article ID" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Como Declarar o Imposto de Renda 2026 — Guia Completo\",\n  \"briefing\": \"Atualizado com as novas regras da Receita Federal.\",\n  \"readingTime\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Partially update an article. All fields are optional. **Requires ADMIN role.**"
          },
          "response": []
        },
        {
          "name": "Publish Article (Admin)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/articles/:id/publish",
              "host": ["{{baseUrl}}"],
              "path": ["articles", ":id", "publish"],
              "variable": [{ "key": "id", "value": "clx8def456", "description": "Article ID" }]
            },
            "description": "Transition an article to `PUBLISHED` status and set `publishedAt` timestamp. No request body required.\n\n**Requires ADMIN role.**"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": {\n    \"id\": \"clx8def456\",\n    \"status\": \"PUBLISHED\",\n    \"publishedAt\": \"2026-03-08T12:00:00.000Z\"\n  },\n  \"_links\": {\n    \"self\": { \"href\": \"/articles/slug/como-declarar-imposto-renda-2026\", \"method\": \"GET\" },\n    \"collection\": { \"href\": \"/articles\", \"method\": \"GET\" }\n  }\n}"
            }
          ]
        },
        {
          "name": "Archive Article (Admin)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/articles/:id/archive",
              "host": ["{{baseUrl}}"],
              "path": ["articles", ":id", "archive"],
              "variable": [{ "key": "id", "value": "clx8def456", "description": "Article ID" }]
            },
            "description": "Transition an article to `ARCHIVED` status. No request body required.\n\n**Requires ADMIN role.**"
          },
          "response": []
        },
        {
          "name": "Delete Article (Admin)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/articles/:id",
              "host": ["{{baseUrl}}"],
              "path": ["articles", ":id"],
